// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

enum Role {
  CUSTOMER
  ADMIN
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PACKED
  SHIPPED
  OUT_FOR_DELIVERY
  DELIVERED
  CANCELLED
  REFUNDED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum PaymentProvider {
  RAZORPAY
  COD
}

enum CouponType {
  PERCENT
  FLAT
}

enum LoyaltyTxnType {
  EARNED
  REDEEMED
  EXPIRED
  ADJUSTED
}

model User {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  email         String    @unique
  phone         String?   @unique
  passwordHash  String?
  name          String?
  role          Role      @default(CUSTOMER)
  emailVerified DateTime?
  googleId      String?   @unique
  image         String?
  loyaltyPoints Int       @default(0)

  addresses   Address[]
  orders      Order[]
  reviews     Review[]
  wishlist    WishlistItem[]
  cart        Cart?
  loyaltyTxns LoyaltyTransaction[]
  otpCodes    OtpCode[]
  pushSubs    PushSubscription[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model OtpCode {
  id         String    @id @default(auto()) @map("_id") @db.ObjectId
  user       User?     @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  userId     String?   @db.ObjectId
  identifier String
  code       String
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([identifier])
}

model Address {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  user      User     @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  userId    String   @db.ObjectId
  label     String?
  fullName  String
  phone     String
  line1     String
  line2     String?
  city      String
  state     String
  pincode   String
  country   String   @default("India")
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())

  orders Order[]

  @@index([userId])
}

model Category {
  id          String     @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  slug        String     @unique
  description String?
  imageUrl    String?
  parent      Category?  @relation("CategoryTree", fields: [parentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  parentId    String?    @db.ObjectId
  children    Category[] @relation("CategoryTree")
  products    Product[]
  createdAt   DateTime   @default(now())
}

model Product {
  id                String   @id @default(auto()) @map("_id") @db.ObjectId
  name              String
  slug              String   @unique
  description       String
  category          Category @relation(fields: [categoryId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  categoryId        String   @db.ObjectId
  basePrice         Float
  compareAtPrice    Float?
  images            String[]
  isActive          Boolean  @default(true)
  isFeatured        Boolean  @default(false)
  stockQty          Int      @default(0)
  lowStockThreshold Int      @default(5)
  attributes        Json?

  variants       ProductVariant[]
  reviews        Review[]
  wishlistedBy   WishlistItem[]
  cartItems      CartItem[]
  orderItems     OrderItem[]
  pujaGuideLinks PujaGuideSamagriItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([categoryId])
}

model ProductVariant {
  id         String  @id @default(auto()) @map("_id") @db.ObjectId
  product    Product @relation(fields: [productId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  productId  String  @db.ObjectId
  name       String
  sku        String  @unique
  priceDelta Float   @default(0)
  stockQty   Int     @default(0)
  attributes Json?

  cartItems  CartItem[]
  orderItems OrderItem[]

  @@index([productId])
}

model Cart {
  id         String  @id @default(auto()) @map("_id") @db.ObjectId
  user       User?   @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  userId     String? @unique @db.ObjectId
  guestToken String? @unique

  items CartItem[]

  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
}

model CartItem {
  id        String          @id @default(auto()) @map("_id") @db.ObjectId
  cart      Cart            @relation(fields: [cartId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  cartId    String          @db.ObjectId
  product   Product         @relation(fields: [productId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  productId String          @db.ObjectId
  variant   ProductVariant? @relation(fields: [variantId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  variantId String?         @db.ObjectId
  quantity  Int             @default(1)
  createdAt DateTime        @default(now())

  @@unique([cartId, productId, variantId])
}

model Coupon {
  id            String     @id @default(auto()) @map("_id") @db.ObjectId
  code          String     @unique
  type          CouponType
  value         Float
  minOrderValue Float?
  maxDiscount   Float?
  usageLimit    Int?
  usedCount     Int        @default(0)
  validFrom     DateTime
  validTo       DateTime
  isActive      Boolean    @default(true)
  orders        Order[]
  createdAt     DateTime   @default(now())
}

model Order {
  id                  String          @id @default(auto()) @map("_id") @db.ObjectId
  orderNumber         String          @unique
  user                User?           @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  userId              String?         @db.ObjectId
  guestEmail          String?
  guestName           String?
  address             Address?        @relation(fields: [addressId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  addressId           String?         @db.ObjectId
  shippingSnapshot    Json
  items               OrderItem[]
  coupon              Coupon?         @relation(fields: [couponId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  couponId            String?         @db.ObjectId
  subtotal            Float
  discount            Float           @default(0)
  shippingFee         Float           @default(0)
  total               Float
  status              OrderStatus     @default(PENDING)
  paymentStatus       PaymentStatus   @default(PENDING)
  paymentProvider     PaymentProvider @default(RAZORPAY)
  razorpayOrderId     String?
  razorpayPaymentId   String?
  razorpaySignature   String?
  loyaltyPointsEarned Int             @default(0)

  statusEvents OrderStatusEvent[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model OrderItem {
  id            String          @id @default(auto()) @map("_id") @db.ObjectId
  order         Order           @relation(fields: [orderId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  orderId       String          @db.ObjectId
  product       Product         @relation(fields: [productId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  productId     String          @db.ObjectId
  variant       ProductVariant? @relation(fields: [variantId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  variantId     String?         @db.ObjectId
  nameSnapshot  String
  priceSnapshot Float
  quantity      Int

  @@index([orderId])
  @@index([productId])
}

model OrderStatusEvent {
  id        String      @id @default(auto()) @map("_id") @db.ObjectId
  order     Order       @relation(fields: [orderId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  orderId   String      @db.ObjectId
  status    OrderStatus
  note      String?
  createdAt DateTime    @default(now())

  @@index([orderId])
}

model Review {
  id                 String   @id @default(auto()) @map("_id") @db.ObjectId
  product            Product  @relation(fields: [productId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  productId          String   @db.ObjectId
  user               User     @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  userId             String   @db.ObjectId
  rating             Int
  title              String?
  body               String?
  photos             String[]
  isVerifiedPurchase Boolean  @default(false)
  helpfulCount       Int      @default(0)
  isApproved         Boolean  @default(true)
  createdAt          DateTime @default(now())

  @@unique([productId, userId])
}

model WishlistItem {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  user      User     @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  userId    String   @db.ObjectId
  product   Product  @relation(fields: [productId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  productId String   @db.ObjectId
  createdAt DateTime @default(now())

  @@unique([userId, productId])
}

model LoyaltyTransaction {
  id        String         @id @default(auto()) @map("_id") @db.ObjectId
  user      User           @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  userId    String         @db.ObjectId
  points    Int
  type      LoyaltyTxnType
  orderId   String?
  note      String?
  createdAt DateTime       @default(now())

  @@index([userId])
}

model PujaGuide {
  id               String   @id @default(auto()) @map("_id") @db.ObjectId
  name             String
  slug             String   @unique
  description      String
  preparationSteps Json
  mantras          Json
  videoUrl         String?
  pdfUrl           String?

  samagriItems PujaGuideSamagriItem[]

  createdAt DateTime @default(now())
}

model PujaGuideSamagriItem {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  pujaGuide   PujaGuide @relation(fields: [pujaGuideId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  pujaGuideId String    @db.ObjectId
  product     Product   @relation(fields: [productId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  productId   String    @db.ObjectId
  quantity    Int       @default(1)

  @@index([pujaGuideId])
}

model WisdomEntry {
  id         String    @id @default(auto()) @map("_id") @db.ObjectId
  type       String
  title      String?
  content    Json
  activeDate DateTime?
  createdAt  DateTime  @default(now())

  @@index([type])
}

model PushSubscription {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  user      User?    @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  userId    String?  @db.ObjectId
  fcmToken  String   @unique
  createdAt DateTime @default(now())
}
