{
  "name": "keshavi",
  "private": true,
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "dev": "concurrently -n BACKEND,FRONTEND -c green,blue \"npm run dev -w backend\" \"npm run dev -w frontend\"",
    "dev:backend": "npm run dev -w backend",
    "dev:frontend": "npm run dev -w frontend",
    "build": "npm run build -w backend && npm run build -w frontend",
    "prisma:generate": "npm run prisma:generate -w backend",
    "prisma:push": "npm run prisma:push -w backend",
    "prisma:seed": "npm run prisma:seed -w backend",
    "prisma:studio": "npm run prisma:studio -w backend"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  }
}
